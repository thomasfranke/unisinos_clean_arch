 Icon(\n              isFavorite ? Icons.star : Icons.star_outline,\n              color: isFavorite ? Colors.amber : Colors.grey,\n            ),\n            onPressed: () =>\n                context.read<FavoritesNotifier>().toggleFavorite(quote.symbol),\n          ),\n        ],\n      ),\n      onTap: () async {\n        await context.router.push(CryptoQuoteDetailRoute(quote: quote));\n      },\n    );\n  }\n}"},"metrics":[{"metricsId":"number-of-methods","value":2,"unitType":"methods","level":"none","comment":"This class has 2 methods.","context":[{"message":"constructor QuoteTile increase metric value","codeSpan":{"start":{"offset":987,"line":16,"column":3},"end":{"offset":1037,"line":16,"column":53},"text":"const QuoteTile({required this.quote, super.key});"}},{"message":"method build increase metric value","codeSpan":{"start":{"offset":1135,"line":22,"column":3},"end":{"offset":2844,"line":71,"column":4},"text":"Widget build(final BuildContext context) {\n    final bool isPositive = quote.priceChangePct >= 0;\n\n    final FavoritesState favoritesState = context\n        .watch<FavoritesNotifier>()\n        .state;\n    final bool isFavorite = switch (favoritesState) {\n      FavoritesStateSuccess(:final List<FavoriteEntity> favorites) =>\n        favorites.any((final FavoriteEntity f) => f.symbol == quote.symbol),\n      _ => false,\n    };\n\n    return ListTile(\n      title: Text(quote.symbol),\n      subtitle: Text('Vol: ${quote.quoteVolume.toStringAsFixed(2)}'),\n      trailing: Row(\n        mainAxisSize: MainAxisSize.min,\n        children: <Widget>[\n          Column(\n            mainAxisAlignment: MainAxisAlignment.center,\n            crossAxisAlignment: CrossAxisAlignment.end,\n            children: <Widget>[\n              Text(\n                quote.lastPrice.toStringAsFixed(2),\n                style: const TextStyle(fontWeight: FontWeight.bold),\n              ),\n              Text(\n                '''${isPositive ? '+' : ''}${quote.price