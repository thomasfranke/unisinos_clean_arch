ment.center,\n          children: <Widget>[\n            Icon(Icons.star_outline, size: 48, color: Colors.grey),\n            SizedBox(height: 16),\n            Text('Nenhum favorito ainda', style: TextStyle(color: Colors.grey)),\n          ],\n        ),\n      );\n    }\n\n    return QuoteList(\n      quotes: favoriteQuotes,\n      onRefresh: () => context.read<CryptoQuoteNotifier>().fetchQuotes(),\n    );\n  }\n}"},"metrics":[{"metricsId":"number-of-methods","value":3,"unitType":"methods","level":"none","comment":"This class has 3 methods.","context":[{"message":"constructor FavoritesTab increase metric value","codeSpan":{"start":{"offset":874,"line":14,"column":3},"end":{"offset":928,"line":14,"column":57},"text":"const FavoritesTab({required this.quotes, super.key});"}},{"message":"method build increase metric value","codeSpan":{"start":{"offset":1059,"line":20,"column":3},"end":{"offset":1604,"line":35,"column":4},"text":"Widget build(final BuildContext context) {\n    final FavoritesState favoritesState = context\n        .watch<FavoritesNotifier>()\n        .state;\n\n    return switch (favoritesState) {\n      FavoritesStateInitial() || FavoritesStateLoading() => const Center(\n        child: CircularProgressIndicator(strokeWidth: 2),\n      ),\n      FavoritesStateFailure(:final String message) => Center(\n        child: Text(message),\n      ),\n      FavoritesStateSuccess(:final List<FavoriteEntity> favorites) =>\n        _buildList(context, favorites),\n    };\n  }"}},{"message":"method _buildList increase metric value","codeSpan":{"start":{"offset":1608,"line":37,"column":3},"end":{"offset":2459,"line":65,"column":4},"text":"Widget _buildList(\n    final BuildContext context,\n    final List<FavoriteEntity> favorites,\n  ) {\n    final List<CryptoQuoteEntity> favoriteQuotes = quotes\n        .where(\n          (final CryptoQuoteEntity q) =>\n              favorites.any((final FavoriteEntity f) => f.symbol == q.symbol),\n        )\n        .toList();\n\